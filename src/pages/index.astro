<style>
	/* --- Design System & Base Settings --- */
	:root {
		--font-main: 'Noto Sans JP', sans-serif;
		--font-accent: 'Zen Maru Gothic', sans-serif;
		
		/* Warm & Natural Color Palette */
		--color-bg: #FCF8F2; /* Creamy White */
		--color-text: #2C1D11; /* Warm Dark Brown (much softer than black) */
		--color-text-muted: #5C4A3A;
		--color-primary: #D35400; /* Rich Terracotta Orange */
		--color-primary-light: #E67E22; /* Warm Tangerine */
		--color-primary-bg: #FBEFE5; /* Light Orange/Beige for accent block background */
		--color-secondary: #2E7D32; /* Deep Forest Green for warm organic contrast */
		--color-secondary-light: #388E3C;
		--color-accent: #E67E22;
		--color-card-bg: #FFFFFF;
		--color-border: #EFE4D8;
		--shadow-sm: 0 2px 8px rgba(44, 29, 17, 0.05);
