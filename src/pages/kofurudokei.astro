<style>
	/* --- Design System (Forest, Wood & Antique Clock Theme) --- */
	:root {
		--font-serif: 'Noto Serif JP', Georgia, serif;
		--font-sans: 'Zen Maru Gothic', 'Noto Sans JP', sans-serif;
		
		/* Warm Antique & Deep Forest Colors */
		--color-bg: #FAF6F0; /* Soft warm ivory */
		--color-text: #2B1810; /* Dark Walnut Brown */
		--color-text-muted: #5D4A40;
		--color-primary: #3E2723; /* Deep Mahogony Brown */
		--color-primary-light: #5D4037;
		--color-primary-bg: #EFE5D8; /* Warm light wood beige */
		
		--color-forest: #1B3B2B; /* Deep Forest Green */
		--color-forest-light: #2A543E;
		--color-forest-bg: #E3EDE8;
		
		--color-brass: #B9935A; /* Antique Brass / Gold */
		--color-brass-light: #CBB084;
		--color-brass-dark: #916E3B;
		
		--color-card-bg: #FFFFFF;
		--color-border: #E5DACB;
		
		--shadow-sm: 0 4px 12px rgba(43, 24, 16, 0.04);
		--shadow-md: 0 12px 32px rgba(43, 24, 16, 0.08);
		--shadow-lg: 0 20px 48px rgba(43, 24, 16, 0.12);
		
		--radius-sm: 8px;
		--radius-md: 16px;
		--radius-lg: 24px;
		
		--max-width: 1100px;
		--transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
	}

	/* Reset */
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: var(--font-sans);
		background-color: var(--color-bg);
		color: var(--color-text);
		line-height: 1.8;
		overflow-x: hidden;
	}

	a {
		color: inherit;
		text-decoration: none;
		transition: var(--transition);
	}

	/* Common Headings */
	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-subtitle {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 0.18em;
		color: var(--color-brass-dark);
		display: block;
		margin-bottom: 0.5rem;
		text-transform: uppercase;
	}

	.section-title {
		font-family: var(--font-serif);
		font-size: 2.2rem;
		font-weight: 700;
		color: var(--color-primary);
		position: relative;
		display: inline-block;
		padding-bottom: 15px;
	}

	.section-title::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: 50px;
		height: 3px;
		background-color: var(--color-brass);
		border-radius: 2px;
	}

	.section-desc {
		margin-top: 1rem;
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	/* Buttons */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.9rem 2.2rem;
		font-weight: 700;
		border-radius: 50px;
		font-family: var(--font-serif);
		letter-spacing: 0.05em;
		cursor: pointer;
		transition: var(--transition);
		border: none;
		font-size: 0.95rem;
	}

	.btn-primary {
		background-color: var(--color-forest);
		color: #ffffff;
		box-shadow: 0 4px 15px rgba(27, 59, 43, 0.25);
	}

	.btn-primary:hover {
		background-color: var(--color-forest-light);
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(27, 59, 43, 0.35);
	}

	.btn-secondary {
		background-color: transparent;
		color: #ffffff;
		border: 2px solid rgba(255, 255, 255, 0.4);
		backdrop-filter: blur(4px);
	}

	.btn-secondary:hover {
		background-color: rgba(255, 255, 255, 0.15);
		border-color: #ffffff;
		transform: translateY(-2px);
	}

	.btn-map {
		background-color: var(--color-primary);
		color: #ffffff;
		font-size: 0.9rem;
		padding: 0.8rem 1.8rem;
		box-shadow: 0 4px 12px rgba(62, 39, 35, 0.2);
	}

	.btn-map:hover {
		background-color: var(--color-primary-light);
		transform: translateY(-2px);
		box-shadow: 0 8px 18px rgba(62, 39, 35, 0.3);
	}

	.map-btn-icon {
		width: 18px;
		height: 18px;
		margin-right: 8px;
	}

	/* --- Header --- */
	.header {
		background-color: rgba(26, 17, 12, 0.95);
		border-bottom: 2px solid var(--color-brass-dark);
		position: sticky;
		top: 0;
		z-index: 100;
		color: #F5EFE6;
		box-shadow: var(--shadow-sm);
	}

	.header-container {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 1.2rem 1.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo-area {
		display: flex;
		flex-direction: column;
	}

	.logo-text {
		font-family: var(--font-serif);
		font-size: 1.7rem;
		font-weight: 700;
		color: var(--color-brass);
		line-height: 1.25;
		letter-spacing: 0.05em;
	}

	.tagline {
		font-size: 0.72rem;
		color: #BCAAA4;
		font-weight: 400;
		margin-top: 4px;
		letter-spacing: 0.02em;
	}

	.nav-menu {
		display: flex;
		gap: 1.8rem;
	}

	.nav-link {
		font-weight: 400;
		font-size: 0.92rem;
		color: #E0D5C1;
		padding: 0.25rem 0;
		position: relative;
	}

	.nav-link:hover {
		color: var(--color-brass);
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 100%;
		height: 1.5px;
		background-color: var(--color-brass);
		transform: scaleX(0);
		transform-origin: right;
		transition: transform 0.3s ease;
	}

	.nav-link:hover::after {
		transform: scaleX(1);
		transform-origin: left;
	}

	/* --- Hero Section --- */
	.hero {
		background-color: #1A110C; /* Dark walnut wood color */
		color: #F5EFE6;
		padding: 6rem 1.5rem;
		position: relative;
		overflow: hidden;
		/* Subtle stripe pattern to simulate wood paneling vertical lines */
		background-image: 
			linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px),
			linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5));
		background-size: 40px 100%, 100% 100%;
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		/* Forest green vignette vignette */
		background: radial-gradient(circle at center, transparent 30%, rgba(27, 59, 43, 0.45) 100%);
		pointer-events: none;
	}

	.hero-container {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 4rem;
		align-items: center;
		position: relative;
		z-index: 2;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.hero-sub {
		font-family: var(--font-serif);
		color: var(--color-brass);
		font-size: 1.1rem;
		font-weight: 400;
		margin-bottom: 0.75rem;
		letter-spacing: 0.1em;
	}

	.hero-title {
		font-family: var(--font-serif);
		font-size: 3.4rem;
		line-height: 1.25;
		margin-bottom: 1.5rem;
		font-weight: 700;
		color: #ffffff;
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
	}

	.hero-desc {
		font-size: 1.05rem;
		color: #D7CCC8;
		margin-bottom: 2.5rem;
		text-align: justify;
		line-height: 1.8;
	}

	.hero-buttons {
		display: flex;
		gap: 1.2rem;
	}

	.clock-illustration-container {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	/* --- Grandfather Clock CSS Graphic --- */
	.grandfather-clock {
		width: 150px;
		height: 380px;
		display: flex;
		flex-direction: column;
		align-items: center;
		position: relative;
		filter: drop-shadow(0 10px 25px rgba(0,0,0,0.6));
	}

	.clock-top {
		width: 110px;
		height: 35px;
		background: linear-gradient(to right, #4E342E, #2D1A12, #4E342E);
		border-radius: 50% 50% 0 0;
		border: 3px solid var(--color-brass-dark);
		border-bottom: none;
	}

	.clock-case {
		width: 100px;
		flex-grow: 1;
		background: linear-gradient(to right, #3E2723, #1A0C06, #3E2723);
		border: 4px solid var(--color-brass-dark);
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 10px 0;
		gap: 15px;
	}

	.clock-face {
		width: 80px;
		height: 80px;
		background-color: #FAF6F0;
		border-radius: 50%;
		border: 5px solid var(--color-brass);
		box-shadow: inset 0 2px 5px rgba(0,0,0,0.3);
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
	}

	.clock-dial {
		width: 100%;
		height: 100%;
		position: relative;
	}

	.center-pin {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 6px;
		height: 6px;
		background-color: var(--color-primary);
		border-radius: 50%;
		transform: translate(-50%, -50%);
		z-index: 10;
	}

	.hand {
		position: absolute;
		background-color: #1A110C;
		transform-origin: bottom center;
		border-radius: 4px;
		left: 50%;
		bottom: 50%;
	}

	.hour-hand {
		width: 3px;
		height: 18px;
		transform: translateX(-50%) rotate(45deg);
	}

	.minute-hand {
		width: 2px;
		height: 26px;
		transform: translateX(-50%) rotate(290deg);
	}

	.index {
		position: absolute;
		font-family: var(--font-serif);
		font-size: 0.65rem;
		font-weight: 700;
		color: #4E342E;
		transform: translateX(-50%);
	}

	.index-12 { top: 4px; left: 50%; }
	.index-3 { right: -2px; top: 50%; transform: translateY(-50%); }
	.index-6 { bottom: 4px; left: 50%; }
	.index-9 { left: 8px; top: 50%; transform: translateY(-50%); }

	.clock-body {
		width: 76px;
		height: 190px;
		background-color: #100602;
		border: 3px solid #27120B;
		border-radius: 4px;
		position: relative;
		overflow: hidden;
	}

	.glass-window {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 60%);
	}

	/* Pendulum swing animation */
	@keyframes pendulum-swing {
		0% { transform: rotate(-8deg); }
		50% { transform: rotate(8deg); }
		100% { transform: rotate(-8deg); }
	}

	.pendulum-holder {
		position: absolute;
		top: 0;
		left: 50%;
		transform-origin: top center;
		animation: pendulum-swing 2.2s ease-in-out infinite;
		display: flex;
		flex-direction: column;
		align-items: center;
		height: 100%;
	}

	.pendulum-rod {
		width: 3px;
		height: 130px;
		background-color: var(--color-brass);
	}

	.pendulum-bob {
		width: 30px;
		height: 30px;
		background: radial-gradient(circle at 35% 35%, var(--color-brass-light) 0%, var(--color-brass) 50%, var(--color-brass-dark) 100%);
		border-radius: 50%;
		border: 2px solid var(--color-brass-dark);
		margin-top: -5px;
		box-shadow: 0 4px 8px rgba(0,0,0,0.5);
	}

	.clock-base {
		width: 116px;
		height: 25px;
		background: linear-gradient(to right, #4E342E, #2D1A12, #4E342E);
		border-radius: 0 0 8px 8px;
		border: 3px solid var(--color-brass-dark);
		border-top: none;
	}

	/* --- Concept Section --- */
	.concept-section {
		padding: 7rem 1.5rem;
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.concept-container {
		display: grid;
		grid-template-columns: 1.12fr 0.88fr;
		gap: 5rem;
		align-items: center;
	}

	.concept-text-block {
		display: flex;
		flex-direction: column;
	}

	.concept-para {
		font-size: 1rem;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
		text-align: justify;
	}

	.concept-para:last-of-type {
		margin-bottom: 0;
	}

	/* Cabin & Forest CSS Illustration */
	.concept-illustration-block {
		display: flex;
		justify-content: center;
	}

	.cabin-frame {
		width: 240px;
		background-color: #3E2723;
		border: 6px solid #2D1A12;
		border-radius: var(--radius-md);
		padding: 15px;
		box-shadow: var(--shadow-md);
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.wood-plank {
		height: 14px;
		background: linear-gradient(to right, #5D4037, #4E342E, #5D4037);
		border-radius: 4px;
		position: relative;
	}

	.wood-plank::after {
		content: '';
		position: absolute;
		left: 15%;
		top: 0;
		width: 2px;
		height: 100%;
		background-color: rgba(0,0,0,0.15);
	}

	.cabin-window {
		height: 180px;
		background-color: #B2DFDB;
		border: 8px solid #2D1A12;
		border-radius: 4px;
		overflow: hidden;
		position: relative;
		box-shadow: inset 0 4px 10px rgba(0,0,0,0.3);
	}

	.forest-view {
		width: 100%;
		height: 100%;
		background: linear-gradient(to bottom, #80DEEA 0%, #E0F7FA 70%, #C8E6C9 100%);
		position: relative;
	}

	.tree {
		position: absolute;
		bottom: 0;
		background-color: var(--color-forest);
		border-radius: 50% 50% 0 0;
	}

	.tree::before {
		content: '';
		position: absolute;
		bottom: -10px;
		left: 50%;
		transform: translateX(-50%);
		width: 4px;
		height: 15px;
		background-color: #5D4037;
	}

	.tree1 {
		width: 50px;
		height: 100px;
		left: 15px;
		background-color: #1B5E20;
		opacity: 0.9;
	}

	.tree2 {
		width: 70px;
		height: 120px;
		right: 20px;
		background-color: var(--color-forest);
		z-index: 2;
	}

	.tree3 {
		width: 40px;
		height: 70px;
		left: 60px;
		background-color: #388E3C;
		opacity: 0.8;
	}

	.sun-ray {
		position: absolute;
		top: 0;
		left: 0;
		width: 150%;
		height: 100%;
		background: linear-gradient(135deg, rgba(255, 235, 59, 0.4) 0%, rgba(255,255,255,0) 50%);
		transform: rotate(-10deg);
		pointer-events: none;
	}

	/* --- Menu Section --- */
	.menu-section {
		max-width: var(--max-width);
		margin: 3rem auto 6rem auto;
		padding: 0 1.5rem;
	}

	.menu-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2.2rem;
	}

	.menu-card {
		background-color: var(--color-card-bg);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		transition: var(--transition);
		display: flex;
		flex-direction: column;
	}

	.menu-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--shadow-lg);
		border-color: var(--color-brass-light);
	}

	.menu-graphic-container {
		padding: 1.5rem;
		background-color: var(--color-primary-bg);
		display: flex;
		justify-content: center;
		align-items: center;
		border-bottom: 1px solid var(--color-border);
	}

	.menu-svg {
		width: 100%;
		max-width: 180px;
		height: auto;
		filter: drop-shadow(0 6px 12px rgba(43,24,16,0.1));
		transition: var(--transition);
	}

	.menu-card:hover .menu-svg {
		transform: scale(1.04) rotate(1deg);
		filter: drop-shadow(0 8px 16px rgba(43,24,16,0.15));
	}

	.menu-info {
		padding: 1.8rem;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
	}

	.menu-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.8rem;
	}

	.menu-name {
		font-family: var(--font-serif);
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-primary);
	}

	.menu-price {
		color: var(--color-brass-dark);
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: 1.25rem;
	}

	.menu-desc {
		font-size: 0.88rem;
		color: var(--color-text-muted);
		line-height: 1.7;
	}

	/* --- Information Section (Hours & Access) --- */
	.info-section {
		background-color: var(--color-forest-bg);
		padding: 6rem 1.5rem;
		border-top: 1px solid rgba(27, 59, 43, 0.1);
		border-bottom: 1px solid rgba(27, 59, 43, 0.1);
	}

	.info-container {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3.5rem;
	}

	.info-card {
		background-color: var(--color-card-bg);
		border-radius: var(--radius-lg);
		padding: 3.5rem 3rem;
		box-shadow: var(--shadow-sm);
		border: 1px solid rgba(27, 59, 43, 0.08);
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.info-icon-container {
		width: 64px;
		height: 64px;
		border-radius: 50%;
		background-color: var(--color-forest-bg);
		color: var(--color-forest);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1.5rem;
	}

	.info-svg {
		width: 30px;
		height: 30px;
	}

	.info-card-title {
		font-family: var(--font-serif);
		font-size: 1.65rem;
		font-weight: 700;
		margin-bottom: 2rem;
		color: var(--color-primary);
		position: relative;
	}

	.info-card-title::after {
		content: '';
		position: absolute;
		bottom: -8px;
		left: 50%;
		transform: translateX(-50%);
		width: 35px;
		height: 2px;
		background-color: var(--color-brass);
	}

	/* Hours Card Details */
	.hours-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
	}

	.hours-time-main {
		font-family: var(--font-serif);
		font-size: 2.4rem;
		font-weight: 700;
		color: var(--color-forest);
		line-height: 1;
		margin-bottom: 1.5rem;
		letter-spacing: 0.05em;
	}

	.hours-days {
		display: flex;
		gap: 0.4rem;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.day-tag {
		font-size: 0.8rem;
		font-weight: 700;
		width: 32px;
		height: 32px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.day-tag.open {
		background-color: var(--color-forest-bg);
		color: var(--color-forest);
		border: 1px solid rgba(27, 59, 43, 0.2);
	}

	.day-tag.closed {
		background-color: #F4E8E4;
		color: #C62828;
		border: 1px solid rgba(198, 40, 40, 0.15);
	}

	.hours-summary {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
	}

	.closed-notice {
		border-top: 1px dashed var(--color-border);
		padding-top: 1.5rem;
		width: 100%;
		font-weight: 700;
		color: var(--color-text);
	}

	.closed-notice span {
		color: #C62828;
	}

	/* Access Card Details */
	.access-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
	}

	.address-main {
		font-family: var(--font-serif);
		font-size: 1.45rem;
		font-weight: 700;
		color: var(--color-primary);
		margin-bottom: 1rem;
	}

	.parking-info {
		font-size: 0.95rem;
		background-color: var(--color-bg);
		padding: 1rem;
		border-radius: var(--radius-sm);
		border-left: 4px solid var(--color-brass);
		margin-bottom: 1.25rem;
		text-align: left;
		line-height: 1.6;
		width: 100%;
	}

	.parking-info strong {
		color: var(--color-primary);
	}

	.station-info {
		font-size: 0.88rem;
		color: var(--color-text-muted);
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	/* --- SNS Section --- */
	.sns-section {
		padding: 6.5rem 1.5rem;
		text-align: center;
	}

	.sns-card {
		max-width: 640px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.sns-title {
		font-family: var(--font-serif);
		font-size: 1.8rem;
		color: var(--color-primary);
		margin-bottom: 1.2rem;
	}

	.sns-text {
		color: var(--color-text-muted);
		margin-bottom: 2.2rem;
		font-size: 0.98rem;
	}

	.instagram-link {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		font-family: var(--font-serif);
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--color-forest);
		padding: 0.85rem 2.2rem;
		border-radius: 50px;
		background-color: var(--color-card-bg);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-sm);
	}

	.instagram-link:hover {
		transform: scale(1.04);
		border-color: var(--color-forest);
		background-color: var(--color-forest-bg);
		box-shadow: var(--shadow-md);
	}

	.instagram-icon {
		width: 22px;
		height: 22px;
	}

	/* --- Footer --- */
	.footer {
		background-color: #1A110C;
		color: #E5DACB;
		padding: 4.5rem 1.5rem 2.5rem 1.5rem;
		border-top: 3px solid var(--color-brass-dark);
	}

	.footer-container {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.footer-brand {
		margin-bottom: 2.5rem;
	}

	.footer-logo {
		font-family: var(--font-serif);
		font-size: 1.9rem;
		font-weight: 700;
		color: #ffffff;
		display: block;
		margin-bottom: 0.4rem;
		letter-spacing: 0.08em;
	}

	.footer-tagline {
		font-size: 0.82rem;
		color: #BCAAA4;
		letter-spacing: 0.02em;
	}

	.footer-links {
		display: flex;
		gap: 2.2rem;
		margin-bottom: 3.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.footer-links a {
		font-size: 0.92rem;
		color: #D7CCC8;
	}

	.footer-links a:hover {
		color: var(--color-brass);
	}

	.footer-copy {
		font-size: 0.75rem;
		color: #70584B;
		border-top: 1px solid rgba(255, 255, 255, 0.04);
		width: 100%;
		padding-top: 1.8rem;
