		--shadow-lg: 0 16px 32px rgba(44, 29, 17, 0.12);
		--radius-sm: 8px;
		--radius-md: 16px;
		--radius-lg: 24px;
		--max-width: 1100px;
		--transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* Reset */
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
